# ─────────────────────────────────────────────────────────────────────────────
# Clinic Management System – root Docker environment
# Copy to .env and fill in all values before running `docker compose up`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Ports exposed on the host ──────────────────────────────────────────────
# Production: only the proxy is public
PROXY_PORT=80

# Development (docker-compose.override.yml): backend & frontend get own ports
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ── Laravel application ────────────────────────────────────────────────────
APP_NAME=CMS
# "production" for docker-compose.yml  |  "local" for docker-compose.override.yml
APP_ENV=production
# Generate with: php artisan key:generate --show
APP_KEY=base64:REPLACE_ME
APP_DEBUG=false
APP_URL=http://localhost

# CORS: must match the origin that browsers see.
# Production (proxy):  http://localhost  (same-origin, CORS not required but set anyway)
# Development:         http://localhost:5173
FRONTEND_URL=http://localhost

# ── Database ───────────────────────────────────────────────────────────────
DB_DATABASE=cms_clinic
DB_USERNAME=cms_user
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
DB_ROOT_PASSWORD=REPLACE_WITH_STRONG_ROOT_PASSWORD

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD

# ── Laravel Passport ───────────────────────────────────────────────────────
# Run `php artisan passport:keys` and `passport:client --personal` once after
# first boot, then set these values.
PASSPORT_CLIENT_ID=
PASSPORT_CLIENT_SECRET=

# ── Mail (optional) ────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=localhost
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=hello@example.com
