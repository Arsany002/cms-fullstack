# ─────────────────────────────────────────────────────────────────────────────
# Clinic Management System – root Docker environment
# ─────────────────────────────────────────────────────────────────────────────

# ── Ports ─────────────────────────────────────────────────────────────────
PROXY_PORT=80
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ── Laravel application ────────────────────────────────────────────────────
APP_NAME=CMS
APP_ENV=production
APP_KEY=base64:YA06nwWwAbZ1rRch+DmkdNJ8AUD4rYmM2fdPiEQwguk=
APP_DEBUG=false
APP_URL=http://localhost
FRONTEND_URL=http://localhost

# ── Database ───────────────────────────────────────────────────────────────
DB_DATABASE=cms_clinic
DB_USERNAME=cms_user
DB_PASSWORD=cms_secret_pass
DB_ROOT_PASSWORD=cms_root_pass

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_PASSWORD=cms_redis_pass

# ── Laravel Passport ───────────────────────────────────────────────────────
# Fill these after first boot: php artisan passport:client --personal
PASSPORT_CLIENT_ID=
PASSPORT_CLIENT_SECRET=

# ── Mail ───────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=localhost
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=hello@example.com
